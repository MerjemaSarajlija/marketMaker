PORT=3000

# Symbols
ARB_SYMBOL=BTCUSDT

# Trigger only when profitable spread >= threshold bps
ARB_SPREAD_BPS=12

# Simulated notional per arbitrage trade
ARB_NOTIONAL_USDT=100

# Per-venue exposure cap
ARB_MAX_POSITION_USDT=1000

# Polling interval for top-of-book snapshots
ARB_POLL_MS=2000

# Exchange endpoints (test environments)
BINANCE_DEMO_BASE_URL=https://testnet.binance.vision
BYBIT_TESTNET_BASE_URL=https://api-testnet.bybit.com
